# Copy to .env and fill in values. Do not commit .env.
TELEGRAM_TOKEN=
OPENAI_API_KEY=
GOOGLE_SHEET_ID=
GOOGLE_CREDENTIALS_JSON=

# Webhook authentication (TG-2). Generate any random string (32+ chars
# recommended), set it here, then run `npm run set-webhook` to register
# it with Telegram. Once set, any POST to /webhook without the matching
# `X-Telegram-Bot-Api-Secret-Token` header is rejected with 401. Leave
# blank in dev to disable the check (a warning will print at startup).
TELEGRAM_WEBHOOK_SECRET=

# Telegram user IDs: admins (approve, add users, banks, ledger) and employees (use bot, writes need approval)
# Each ID must be in ONLY ONE list. Admins skip approval; employees need admin approval for sales/writes.
# Example: one admin, one employee (replace with your Telegram IDs)
ADMIN_IDS=
EMPLOYEE_IDS=8021605452

# Finance role (TG-7.5 Phase C): comma-separated Telegram IDs allowed to see
# task incentive amounts and the Incentives Report. Leave blank to fall back
# to the admin list (current behavior). Narrow this list once you want
# "scrum-master admins" who don't see money.
FINANCE_IDS=

# USR-C3b — super-admins are the only role allowed to APPROVE
# `promote_admin` requests (granting admin power to another user).
# If unset, defaults to ADMIN_IDS so existing deployments don't lock
# out. Production should narrow this to 1–2 trusted owners.
SUPER_ADMIN_IDS=

RISK_THRESHOLD=300
LOW_STOCK_THRESHOLD=100
PORT=3000
BASE_URL=
CURRENCY=NGN
BOT_API_KEY=

# Google Drive folder ID where ALL source-file uploads get backed up:
#   - Photo Receive (P5) — JPG/PNG/WebP/HEIC/PDF packaging slips
#   - Bulk Receive (P2.5) — CSV/XLSX inventory uploads (FILE-C1)
#
# Resolution order (first non-empty wins):
#   SOURCE_GDRIVE_FOLDER_ID > OCR_GDRIVE_FOLDER_ID > GOOGLE_DRIVE_FOLDER_ID
#
# Files land in {FOLDER}/{YYYY-MM}/ with a human-readable name like
# `2026-05-15__abdul__packing-slip__a3f4b9c2.jpg` and the Drive webViewLink
# is written to GoodsReceipts.source_url so the admin can open the
# original directly from the sheet. Optional — when all three are blank,
# uploads are still archived to data/ocr/ (photos) or data/uploads/ (bulk)
# on local disk and the sheet's source_url stays empty.
GOOGLE_DRIVE_FOLDER_ID=
OCR_GDRIVE_FOLDER_ID=
SOURCE_GDRIVE_FOLDER_ID=

# Where `npm run snapshot` writes timestamped copies of the master sheet.
# Falls back to SOURCE_GDRIVE_FOLDER_ID → GOOGLE_DRIVE_FOLDER_ID → Drive root.
# Strongly recommended: a dedicated "Backups" folder.
BACKUP_GDRIVE_FOLDER_ID=

# Photo / PDF OCR (P5). Master switch + provider choice. OCR_ENABLED
# can stay false until you're ready to wire a real provider; the stub
# bypass-flag mode is used by smoke tests and demos.
OCR_ENABLED=false
# stub | openai | google   (only 'stub' implemented today)
OCR_PROVIDER=stub
# OpenAI Vision model used when OCR_PROVIDER=openai
OCR_OPENAI_MODEL=gpt-4o
# Per-row confidence threshold (0..1). Rows below this render red and
# force a manual edit before they can be accepted.
OCR_LOW_CONF=0.7
# Max upload size in bytes (default 5 MB)
OCR_MAX_FILE_BYTES=5242880
# Where local OCR archives land (relative to repo root)
OCR_ARCHIVE_DIR=data/ocr
# Optional: point OCR_STUB_FIXTURE_PATH at a JSON file to override the
# canned stub output (handy for pinning edge-case fixtures in QA).
OCR_STUB_FIXTURE_PATH=
